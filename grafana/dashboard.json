      "title": "Error Rate (5xx)",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(otel_http_server_duration_milliseconds_count{exported_job=~\"$job\", http_status_code=~\"5..\"}[$__rate_interval])) / sum(rate(otel_http_server_duration_milliseconds_count{exported_job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
